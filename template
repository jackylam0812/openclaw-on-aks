#!/bin/bash

yum install -y mdadm

# Find truly unused NVMe devices
NVME_DEVICES=""
for dev in /dev/nvme*n1; do
    if [ -b "$dev" ]; then
        # Skip if mounted or has partitions or in use
        if lsblk -n -o MOUNTPOINT "$dev" | grep -q . || \
           lsblk -n "$dev" | grep -q part || \
           fuser "$dev" 2>/dev/null || \
           mdadm --examine "$dev" 2>/dev/null | grep -q "Magic"; then
            echo "Skipping $dev - in use"
            continue
        fi
        NVME_DEVICES="$NVME_DEVICES $dev"
    fi
done

NVME_DEVICES=$(echo $NVME_DEVICES | xargs)
DEVICE_COUNT=$(echo $NVME_DEVICES | wc -w)

if [ $DEVICE_COUNT -gt 1 ]; then
    echo "Creating RAID0 with $DEVICE_COUNT devices: $NVME_DEVICES"
    mdadm --create /dev/md0 --level=0 --raid-devices=$DEVICE_COUNT $NVME_DEVICES --force --assume-clean
    sleep 10
    mkfs.ext4 -F /dev/md0

    mkdir -p /mnt/celeborn_ratis
    mkdir -p /mnt/disk1
    mkdir -p /mnt/disk2
    mount /dev/md0 /mnt
    echo "/dev/md0 /mnt ext4 defaults,nofail 0 2" >> /etc/fstab



elif [ $DEVICE_COUNT -eq 1 ]; then
    echo "Using single device: $NVME_DEVICES"
    mkfs.ext4 -F $NVME_DEVICES

    mkdir -p /mnt/celeborn_ratis
    mkdir -p /mnt/disk1
    mkdir -p /mnt/disk2
    mount $NVME_DEVICES /mnt
    echo "$NVME_DEVICES /mnt ext4 defaults,nofail 0 2" >> /etc/fstab

else
    echo "No available NVMe devices found"
    exit 0
fi

echo "High-performance storage mounted to /mnt"

